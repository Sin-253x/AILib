# ======================== 代码解释 ========================
# 1. 整体功能：
#    提供 VPS 生产部署所需的环境变量模板。
#
# 2. 关键部分拆解：
#    - AILIB_DOMAIN：Caddy 申请 HTTPS 证书和 Web 构建 API 地址都会使用。
#    - AILIB_IP_HOST：备案放行前的临时 HTTP IP 访问入口，不会申请 HTTPS 证书。
#    - ALLOWED_ORIGINS：FastAPI CORS 白名单；正式域名和临时 IP 入口都应显式列入。
#    - POSTGRES_*：只在 Docker 内网中使用，不应暴露公网端口。
#    - CHAT_* / DEEPSEEK_*：控制 RAG 对话 provider。
#
# 3. 重要概念与库：
#    - env_file：docker compose 会把这些变量注入对应服务。
#    - OpenAI-compatible API：DeepSeek 使用兼容接口，base URL 显式配置。
#    - HTTP fallback：仅用于个人临时访问，备案完成后应优先使用 HTTPS 域名。
#
# 4. 潜在问题与改进建议：
#    - 不要把复制后的 .env.prod 提交到 Git，里面会包含真实密钥。
#    - 使用 AILIB_IP_HOST 时，登录密码和 Cookie 会走明文 HTTP，不适合长期公网使用。
#
# 5. 修改指南：
#    - 部署前复制为 deploy/.env.prod 并替换所有 change-me 和 your_* 值。
#    - 如果暂时没有备案，可把 AILIB_IP_HOST 设置为服务器公网 IP，例如 47.100.43.185。
#    - 使用 HTTP IP 临时访问时，把 AUTH_COOKIE_SECURE 改为 false；备案完成后再改回 true。
# ========================================================
AILIB_DOMAIN=kb.example.com
AILIB_IP_HOST=
ALLOWED_ORIGINS=https://kb.example.com
ACME_EMAIL=you@example.com

POSTGRES_DB=ailib
POSTGRES_USER=ailib
POSTGRES_PASSWORD=change-me-long-random-password

SECRET_KEY=change-me-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_COOKIE_NAME=ailib_access_token
AUTH_COOKIE_SECURE=true

MAX_UPLOAD_SIZE_BYTES=10485760
EMBEDDING_PROVIDER=local
EMBEDDING_DIMENSIONS=1536
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=900
CHUNK_OVERLAP=150

CHAT_PROVIDER=deepseek
CHAT_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_BASE=https://api.deepseek.com
OPENAI_API_KEY=
