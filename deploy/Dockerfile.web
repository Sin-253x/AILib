# ======================== 代码解释 ========================
# 1. 整体功能：
#    为生产部署构建 AILib Next.js Web 工作区镜像。
#
# 2. 关键部分拆解：
#    - deps 阶段：在 monorepo 根目录安装 npm workspace 依赖。
#    - builder 阶段：注入 NEXT_PUBLIC_API_BASE_URL 并执行 Next.js 生产构建。
#    - runner 阶段：复制构建产物和依赖，用 npm workspace 启动 Web 服务。
#
# 3. 重要概念与库：
#    - Docker multi-stage build：把安装、构建和运行阶段分开，减少最终镜像复杂度。
#    - npm workspaces：根 package.json 管理 apps/web 子应用。
#
# 4. 潜在问题与改进建议：
#    - 当前 runner 保留完整 node_modules，镜像体积不是最小；后续可改 Next standalone 输出。
#
# 5. 修改指南：
#    - 如果 NEXT_PUBLIC_API_BASE_URL 改为同域相对路径，需同步 compose build args。
# ========================================================
# 调试说明：Next.js 15 在当前 Docker Desktop 环境中使用 Node 22 构建时，曾在 build trace 阶段出现栈溢出或 SIGSEGV；
# 这里固定到 Node 20 LTS，让云服务器部署和本地 Docker 验证使用同一套稳定运行时。
FROM node:20-bookworm-slim AS deps
WORKDIR /app
# 安装说明：当前 Docker Desktop 环境中 npm install/npm ci 会触发 V8 原生崩溃；
# 使用 Corepack 管理的 Yarn 4，并指定 node-modules 模式，既绕开 npm 安装路径，也保持 Next.js workspace 运行时兼容。
ENV YARN_ENABLE_TELEMETRY=0
ENV YARN_NODE_LINKER=node-modules
COPY package.json ./
COPY apps/web/package.json ./apps/web/package.json
RUN corepack enable && corepack prepare yarn@4.9.4 --activate && yarn install --mode=skip-build

# 构建说明：builder 阶段和 deps 阶段保持同一 Node 版本，避免原生依赖跨版本运行。
FROM node:20-bookworm-slim AS builder
WORKDIR /app
ARG NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
# 构建说明：关闭 Next.js 匿名遥测，减少生产构建中的外部网络与非业务变量。
ENV NEXT_TELEMETRY_DISABLED=1
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY . .
RUN node apps/web/node_modules/next/dist/bin/next build apps/web

# 运行说明：runner 阶段继续使用 Node 20 LTS，确保构建产物和生产运行时一致。
FROM node:20-bookworm-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
# 运行说明：生产容器不需要遥测上报，关闭后也便于离线或内网部署。
ENV NEXT_TELEMETRY_DISABLED=1
COPY package.json package-lock.json ./
COPY apps/web/package.json ./apps/web/package.json
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=builder /app/apps/web/.next ./apps/web/.next
COPY --from=builder /app/apps/web/public ./apps/web/public
EXPOSE 3000
CMD ["node", "apps/web/node_modules/next/dist/bin/next", "start", "apps/web"]
