# ======================== 配置解释 ========================
# 1. 整体功能：
#    为 AILib 私有自用 Docker 部署提供可复制的环境变量模板。
#
# 2. 关键部分拆解：
#    - PRIVATE_BIND_HOST：控制 Web 网关只监听本机，还是开放给 Tailscale/ZeroTier 私网设备。
#    - POSTGRES_*：只在 Docker 内网使用的 PostgreSQL 初始化账号。
#    - SECRET_KEY：FastAPI 签发登录令牌的密钥，实际 .env.private 会由脚本自动替换。
#    - CHAT_PROVIDER/CHAT_MODEL/DEEPSEEK_*：控制 RAG 对话使用 DeepSeek。
#
# 3. 重要概念与库：
#    - Docker Compose env_file：把密钥注入容器，但不提交到 Git。
#    - httpOnly Cookie：登录态由后端设置 Cookie，浏览器脚本不能直接读取。
#
# 4. 潜在问题与改进建议：
#    - PRIVATE_BIND_HOST=0.0.0.0 会让同一局域网设备也能访问 3000 端口，建议配合 Tailscale ACL 或 Windows 防火墙。
#    - PostgreSQL 密码只在首次初始化数据卷时生效，已有数据卷不应随意修改。
#
# 5. 修改指南：
#    - 只在复制出的根目录 .env.private 中填写真实 DEEPSEEK_API_KEY，不要修改并提交本模板。
# ========================================================

PRIVATE_BIND_HOST=127.0.0.1
WEB_PORT=3000

POSTGRES_DB=ailib
POSTGRES_USER=ailib
POSTGRES_PASSWORD=change-this-private-postgres-password

ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
SECRET_KEY=change-this-private-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_COOKIE_NAME=ailib_access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
MAX_UPLOAD_SIZE_BYTES=1048576

EMBEDDING_PROVIDER=local
EMBEDDING_DIMENSIONS=1536
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=900
CHUNK_OVERLAP=150

CHAT_PROVIDER=deepseek
CHAT_MODEL=deepseek-v4-pro
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
